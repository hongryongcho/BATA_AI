# 03_BATA_ALGO 환경 설정
# run_backtest.py 실행 전 이 값들을 채워주세요

# Google Spreadsheet ID
# 만드는 방법: Google Drive → 새 스프레드시트 생성 → URL에서 복사
# URL 예시: https://docs.google.com/spreadsheets/d/[여기가_ID]/edit
SPREADSHEET_ID=여기에_스프레드시트_ID_입력

# Google 인증 경로 (기본값 사용 시 수정 불필요)
GOOGLE_CREDENTIALS_PATH=../02_BATA_MQTT/config/google_credentials.json
GOOGLE_TOKEN_PATH=../02_BATA_MQTT/config/algo_token.json

# 자동 감시 러너 주기(초) - auto_runner.py 에서 사용 가능
AUTO_RUN_INTERVAL_SEC=60
